# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*

# Admin Terminal
ADMIN_PASSWORD=admin123

# AI Puzzle Generation
# Choose one provider: 'anthropic', 'openai', or 'gemini'
# If not set, will auto-detect based on which API key is available
AI_PROVIDER=

# API Keys (at least one required for AI puzzle generation)
# Get Anthropic API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get Google API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=
